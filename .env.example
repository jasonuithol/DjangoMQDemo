# Copy to .env (already done for dev). Never commit the real .env.
# NOTE: hostnames are compose SERVICE names, not localhost, because the app
# container talks to its siblings over the compose network.

DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-only-not-a-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

DATABASE_URL=postgres://platform:platform@postgres:5432/platform
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

PARTNER_WEBHOOK_SECRET=dev-secret-change-me
